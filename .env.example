# Host Data Paths (Default to /opt/app_data)
APP_DATA_DIR=/opt/app_data
WORKSPACE_DIR=/opt/stacks
USER_HOME_DIR=/home/hb2d

# System Settings
PUID=1000
PGID=1000
TZ=Asia/Nicosia

# Database Secrets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=main_db

# App Secrets
N8N_ENCRYPTION_KEY=your_n8n_key_here
